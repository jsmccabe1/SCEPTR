// Define base directory consistently
def projectBase = projectDir

// Define workDir
workDir = "./work"

// Metadata
manifest {
    name            = 'SCEPTR'
    author          = 'James McCabe'
    homePage        = 'https://github.com/jsmccabe1/SCEPTR'
    description     = 'Multi-Resolution Enrichment Profiling Across the Expression Gradient'
    mainScript      = 'main.nf'
    nextflowVersion = '>=21.10.0'
    version         = '1.0.0'
}

// Parameters with flexible defaults
params {
    // Input/Output - these are the main parameters users must override
    reads                 = null
    transcripts           = null
    outdir                = "results"
    
    // Database paths - users can override these
    contaminants_db       = "${projectBase}/data/contaminants/contaminants_uniprot.dmnd"
    uniprot_db            = "${projectBase}/data/uniprot/uniprot.dmnd"

    // Script paths - these point to container locations
    sceptr_base           = "${projectBase}"
    project_dir           = "${projectBase}"
    bin_dir               = "${projectBase}/bin"
    modules_dir           = "${projectBase}/modules"
    annotation_bin        = "${projectBase}/bin/annotation"
    contamination_bin     = "${projectBase}/bin/contamination"
    enrichment_bin        = "${projectBase}/bin/enrichment"
    explot_cli            = "${projectBase}/modules/explot/cli"
    landscape_script      = "${projectBase}/modules/landscape/transcriptome_landscape.py"

    // General contamination filtering parameters
    identity_threshold    = 50.0
    coverage_threshold    = 30.0
    evalue_threshold      = 1e-3
    max_target_seqs       = 20
    taxonomic_filter      = ""
    
    // Host filtering parameters (for parasite/pathogen studies)
    // Choose ONE of these options:
    host_transcriptome    = null                 // Path to host transcriptome FASTA (nucleotide - will be translated)
    host_proteome         = null                 // Path to host proteome FASTA (protein - used directly, faster)
    host_identity         = 95.0                 // Identity threshold for host (%)
    host_coverage         = 50.0                 // Coverage threshold for host (%)
    host_evalue           = 1e-10                // E-value threshold for host
    skip_host_filter      = false                // Skip host filtering even if transcriptome/proteome provided
    
    // UniProt annotation parameters
    uniprot_evalue        = 1e-5
    uniprot_max_target_seqs = 1
    
    // Expression analysis parameters
    tpm_threshold         = 1.0
    expression_tiers      = "50,100,250,500"
    go_pvalue_cutoff      = 0.05
    bootstrap_n           = 50
    min_fold_enrichment   = 1.5
    confidence_level      = 0.95

    // Enrichment profiling parameters
    skip_explot                   = false
    explot_tiers                  = "50,100,250,500"
    explot_multi_category         = true
    explot_min_percentage         = 5.0
    explot_p_threshold            = 0.05
    explot_correction_method      = "fdr_bh"
    explot_expand_go              = false    // GO expansion off by default (keyword matching only)
    explot_go_expansion_depth     = 2        // Max GO descendant depth if expansion enabled
    integrated_results            = null
    
    // Category system
    category_set                     = "general"
    custom_functional_categories     = null
    custom_cellular_categories       = null
    explot_functional_categories     = null
    explot_cellular_categories       = null
    available_category_sets          = "general,parasite_protozoan,parasite_metazoan,protist_dinoflagellate,model_organism,plant,bacteria,bacteria_gram_negative,bacteria_gram_positive,virus,vertebrate_host,vertebrate_host_hallmark,fungi,cancer,insect,custom"

    // Landscape analysis
    skip_landscape                   = false
    landscape_top_genes              = 30
    landscape_top_taxa               = 20

    // Read layout
    single_end                       = false
    fld_mean                         = 250    // Fragment length mean (single-end only)
    fld_sd                           = 25     // Fragment length SD (single-end only)

    // TransDecoder
    proteome              = null     // Path to pre-translated protein FASTA - skips TransDecoder and DirectTranslate entirely
    skip_transdecoder     = false    // Set to true for CDS inputs (bacteria, viruses) to bypass TransDecoder
    skip_contamination    = false    // Set to true to skip contaminant filtering (auto-enabled for bacteria, virus, vertebrate_host, model_organism)
    min_prot_len          = 50
    output_prefix         = "sceptr"
    debug                 = false

    // Cross-sample comparison parameters
    condition_a           = null
    condition_b           = null
    label_a               = null
    label_b               = null
    n_permutations        = 10000
    comparison_seed       = 42
}

// Process configuration
process {
    container = 'sceptr:1.0.0'
    stageInMode = 'copy'  // Reliable across all systems
    
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        overwrite: true
    ]
    
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = '-1'

    withLabel: process_low {
        cpus = 1
        memory = '2 GB'
    }

    withLabel: process_medium {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }

    withLabel: process_high {
        cpus = 8
        memory = { 16.GB * task.attempt }
        time = { 2.h * task.attempt }
    }

    // Host filtering processes
    withName: 'TranslateHostTranscriptome' {
        memory = { 8.GB * task.attempt }
        cpus = 4
        time = { 1.h * task.attempt }
    }
    
    withName: 'BuildHostDatabase' {
        memory = { 4.GB * task.attempt }
        cpus = 4
        time = '30m'
    }
    
    withName: 'FilterHostSequences' {
        memory = { 4.GB * task.attempt }
        cpus = 4
        time = { 1.h * task.attempt }
    }

    // Contamination detection - memory scales with retries for large datasets
    withName: 'DiamondBlastContaminants' {
        memory = { 16.GB * task.attempt }
        cpus = 8
        time = { 4.h * task.attempt }
    }
    
    // Other processes
    withName: 'TPMGOEnrichment' {
        memory = { 8.GB * task.attempt }
        cpus = 1
        time = { 4.h * task.attempt }
    }
}

// Profile system
profiles {
    
    docker {
        docker.enabled = true
        singularity.enabled = false
        
        // Override ONLY script paths to container locations
        params.bin_dir = "/app/bin"
        params.modules_dir = "/app/modules"
        params.annotation_bin = "/app/bin/annotation"
        params.contamination_bin = "/app/bin/contamination"
        params.enrichment_bin = "/app/bin/enrichment"
        params.explot_cli = "/app/modules/explot/cli"
        params.landscape_script = "/app/modules/landscape/transcriptome_landscape.py"
    }
    
    singularity {
        docker.enabled = false
        singularity.enabled = true
        process.container = 'docker://sceptr:1.0.0'
        process.stageInMode = 'copy'
        
        // Override ONLY script paths to container locations
        params.bin_dir = "/app/bin"
        params.modules_dir = "/app/modules"
        params.annotation_bin = "/app/bin/annotation"
        params.contamination_bin = "/app/bin/contamination"
        params.enrichment_bin = "/app/bin/enrichment"
        params.explot_cli = "/app/modules/explot/cli"
        params.landscape_script = "/app/modules/landscape/transcriptome_landscape.py"
    }
    
    local {
        docker.enabled = false
        singularity.enabled = false
        process.container = null
        process.stageInMode = 'symlink'
    }
    
    test {
        docker.enabled = true
        process.container = 'sceptr:1.0.0'
        process.stageInMode = 'copy'
        
        // Test with smaller expression tiers
        params.expression_tiers = "10,25"
        
        // Override script paths for container
        params.bin_dir = "/app/bin"
        params.annotation_bin = "/app/bin/annotation"
        params.contamination_bin = "/app/bin/contamination"
        params.enrichment_bin = "/app/bin/enrichment"
        params.explot_cli = "/app/modules/explot/cli"
        params.landscape_script = "/app/modules/landscape/transcriptome_landscape.py"
    }
}

// Reporting
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}

// Environment variables - only relevant inside containers
// (Container profiles set PATH via the Docker image ENV directive)
